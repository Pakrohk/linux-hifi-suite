pkgbase = hifi-suite-git
	pkgdesc = Zero-config audio suite for wireless headsets: volume control, surround, NC, EQ, battery monitor
	pkgver = 1.0.0
	pkgrel = 1
	url = https://github.com/Pakrohk/linux-hifi-suite
	install = hifi-suite.install
	arch = any
	license = MIT
	makedepends = git
	depends = python
	depends = python-typer
	depends = alsa-utils
	depends = pipewire
	depends = pipewire-alsa
	depends = pipewire-pulse
	optdepends = noise-suppression-for-voice: RNNoise LADSPA plugin (recommended for NC)
	optdepends = virtual-surround-manager: Virtual 7.1/5.1 surround with HeSuVi WAV (recommended for surround)
	optdepends = easyeffects: GUI audio effects (EQ, compressor, limiter)
	optdepends = realtime-privileges: low-latency audio
	optdepends = gnome-shell: GNOME Shell extension
	optdepends = plasma-desktop: KDE Plasma widget
	optdepends = cinnamon: Cinnamon applet
	provides = hifi-suite
	provides = redragon-audio-suite
	conflicts = hifi-suite
	conflicts = redragon-audio-suite-git
	conflicts = redragon-hs-companion
	conflicts = redragon-hs-companion-git
	replaces = redragon-audio-suite-git
	source = hifi-suite-git::git+https://github.com/Pakrohk/linux-hifi-suite.git
	md5sums = SKIP

pkgname = hifi-suite-git
