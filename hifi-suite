#!/bin/bash
# hifi-suite — unified audio control CLI (wpctl-based, zero-config)
SOCK="${XDG_RUNTIME_DIR:-/tmp}/hifi-suite.sock"
PW_FILTER="${XDG_CONFIG_HOME:-$HOME/.config}/pipewire/filter-chain.conf.d"
WP_RULES="${XDG_CONFIG_HOME:-$HOME/.config}/wireplumber/wireplumber.conf.d"

usage() {
    cat <<'EOF'
Usage: hifi-suite <command> [args]

Volume:
  hifi-suite vol <0-100>       Set volume
  hifi-suite vol <0-100>+      Relative increase
  hifi-suite vol <0-100>-      Relative decrease
  hifi-suite vol mute          Toggle mute
  hifi-suite vol get           Get current volume

Devices:
  hifi-suite devices           List all audio devices (wpctl)
  hifi-suite default           Set headset as default output

Effects:
  hifi-suite enable <nc|surround|eq|ec>
  hifi-suite disable <nc|surround|eq|ec>
  hifi-suite effects           List all effects and status

Mic Preference:
  hifi-suite mic-prefer <node.name> [priority]   Auto-prefer mic
  hifi-suite mic-prefer-regex <pattern> [prio]   Regex match mic
  hifi-suite mic-rules         List active mic rules
  hifi-suite mic-unprefer      Remove mic preference rule

Combined Output:
  hifi-suite combine <name> <sink1> <sink2> [...]   Simultaneous output
  hifi-suite combine-remove <name>                  Remove combined sink

EasyEffects:
  hifi-suite ee-list           List EasyEffects presets
  hifi-suite ee-load <name>    Load an EasyEffects preset
  hifi-suite ee-start          Start EasyEffects
  hifi-suite ee-stop           Stop EasyEffects

Auto:
  hifi-suite auto              Auto-detect and configure everything

Daemon:
  hifi-suite daemon start|stop|restart|status
EOF
}

send() {
    if [ ! -S "$SOCK" ]; then
        systemctl --user start hifi-daemon 2>/dev/null || \
            nohup python3 "$(dirname "$0")/hifi-daemon.py" &>/dev/null &
        sleep 0.3
    fi
    printf '%s' "$1" | socat - "UNIX-CONNECT:$SOCK" 2>/dev/null && return 0
    printf '%s' "$1" | ncat -U "$SOCK" 2>/dev/null && return 0
    printf '%s' "$1" | nc -U -N "$SOCK" 2>/dev/null && return 0
    printf '%s' "$1" | nc -U "$SOCK" 2>/dev/null && return 0
    python3 - "$SOCK" "$1" 2>/dev/null <<'PY'
import socket,sys
s=socket.socket(socket.AF_UNIX,socket.SOCK_STREAM)
s.connect(sys.argv[1]);s.sendall(sys.argv[2].encode());s.shutdown(socket.SHUT_WR)
d=[]
while True:
    c=s.recv(1024)
    if not c:break
    d.append(c)
print(b"".join(d).decode(),end="")
s.close()
PY
}

# ── Volume ────────────────────────────────────────────────────────────────
cmd_vol() {
    local arg="${1:-}"
    case "$arg" in
        ""|[gG][eE][tT])
            local r=$(send "get")
            [[ "$r" == OK:* ]] && echo "${r#OK: }%" || { echo "$r" >&2; return 1; } ;;
        [mM][uU][tT][eE]) send "mute" ;;
        [0-9]|[0-9][0-9]|100) send "set $arg" ;;
        +[0-9]*|-[0-9]*)
            local cur=$(cmd_vol get 2>/dev/null); cur=${cur%\%}
            local new=$((cur + arg))
            (( new < 0 )) && new=0; (( new > 100 )) && new=100
            send "set $new" ;;
        *) echo "Bad volume: $arg" >&2; return 1 ;;
    esac
}

# ── Devices ───────────────────────────────────────────────────────────────
cmd_devices() {
    wpctl status 2>/dev/null || echo "wpctl not found — install pipewire"
}

cmd_default() { send "default"; }

# ── Effects ───────────────────────────────────────────────────────────────
cmd_enable() {
    local f="$1"
    mkdir -p "$PW_FILTER"

    case "$f" in
        nc)
            # Auto-create virtual mic with noise cancellation
            local plugin=""
            for p in /usr/lib/ladspa/librnnoise_ladspa.so \
                     /usr/lib64/ladspa/librnnoise_ladspa.so \
                     /usr/lib/x86_64-linux-gnu/ladspa/librnnoise_ladspa.so; do
                [ -f "$p" ] && plugin="$p" && break
            done
            if [ -z "$plugin" ]; then
                echo "RNNoise not found. Install: noise-suppression-for-voice" >&2
                return 1
            fi
            cat > "$PW_FILTER/nc.conf" <<NCEOF
// HiFi Suite — Noise Cancelling Virtual Microphone
// Select "Noise Cancelling Mic" as your input source. Done.
context.modules = [
    { name = libpipewire-module-filter-chain
        flags = [ nofail ]
        args = {
            node.description = "Noise Cancelling Mic"
            media.name       = "Noise Cancelling Mic"
            filter.graph = {
                nodes = [
                    { type = ladspa name = rnnoise
                      plugin = "$plugin"
                      label  = noise_suppressor_mono
                      control = {
                          "VAD Threshold (%)"          = 50.0
                          "VAD Grace Period (ms)"      = 200
                          "Retroactive VAD Grace (ms)" = 0
                      } }
                ]
            }
            audio.rate = 48000
            capture.props = { node.name = "capture.hifi_rnnoise" node.passive = true audio.rate = 48000 }
            playback.props = { node.name = "hifi_rnnoise_source" media.class = Audio/Source audio.rate = 48000 node.description = "Noise Cancelling Mic" }
        }
    }
]
NCEOF
            systemctl --user restart pipewire wireplumber 2>/dev/null
            echo "Created virtual mic: 'Noise Cancelling Mic'"
            echo "Select it as your input source — noise is auto-removed."
            ;;
        surround|surround714)
            # Try virtual-surround-manager first (best UX)
            if command -v virtual-surround-manager &>/dev/null; then
                echo "Launching virtual-surround-manager..."
                echo "Select a HeSuVi WAV preset in the GUI. Done."
                virtual-surround-manager &
                return 0
            fi
            # Check Flatpak
            if flatpak list --app 2>/dev/null | grep -qi virtual_surround_manager; then
                echo "Launching virtual-surround-manager (Flatpak)..."
                flatpak run de.berny23.virtual_surround_manager &
                return 0
            fi
            # Fallback: SOFA filter chain
            local tpl="/usr/share/hifi-suite/configs/$f.conf"
            if [ -f "$tpl" ]; then
                cp "$tpl" "$PW_FILTER/$f.conf"
                systemctl --user restart pipewire wireplumber 2>/dev/null
                echo "Created virtual surround sink."
                echo "Select it as your output — spatial audio is automatic."
            else
                echo "Surround: install virtual-surround-manager (recommended):" >&2
                echo "  yay -S virtual-surround-manager" >&2
                echo "  or: flatpak install flathub de.berny23.virtual_surround_manager" >&2
                return 1
            fi ;;
        eq)
            local tpl="/usr/share/hifi-suite/configs/$f.conf"
            if [ -f "$tpl" ]; then
                cp "$tpl" "$PW_FILTER/$f.conf"
                systemctl --user restart pipewire wireplumber 2>/dev/null
                echo "Created virtual EQ sink."
                echo "Select it as your output — equalization is automatic."
            else
                echo "EQ .wav needed. Download from https://autoeq.app" >&2
                return 1
            fi ;;
        ec)
            local tpl="/usr/share/hifi-suite/configs/$f.conf"
            if [ -f "$tpl" ]; then
                cp "$tpl" "$PW_FILTER/$f.conf"
                systemctl --user restart pipewire wireplumber 2>/dev/null
                echo "Created echo-cancelled mic."
                echo "Select it as your input — echo is auto-removed."
            else
                echo "No EC config template found." >&2
                return 1
            fi ;;
        *) echo "Unknown effect: $f" >&2; return 1 ;;
    esac
}

cmd_disable() {
    rm -f "$PW_FILTER/$1.conf" 2>/dev/null
    systemctl --user restart pipewire wireplumber 2>/dev/null
    echo "Disabled: $1"
}

cmd_effects() {
    echo "Effects:"
    for f in nc surround surround714 eq ec; do
        [ -f "$PW_FILTER/$f.conf" ] && echo "  $f  ON" || echo "  $f  off"
    done
    echo ""
    pgrep -x easyeffects >/dev/null 2>&1 && echo "EasyEffects: running" || echo "EasyEffects: not running"
}

# ── Mic Preference ────────────────────────────────────────────────────────
cmd_mic_prefer() {
    local node="$1" prio="${2:-2000}"
    mkdir -p "$WP_RULES"
    cat > "$WP_RULES/51-hifi-mic-priority.conf" <<EOF
monitor.alsa.rules = [
  {
    matches = [ { node.name = "$node" } ]
    actions = {
      update-props = {
        priority.session = $prio
        priority.driver  = $prio
      }
    }
  }
]
EOF
    systemctl --user restart wireplumber 2>/dev/null
    echo "Mic preferred: $node (priority $prio)"
}

cmd_mic_prefer_regex() {
    local pattern="$1" prio="${2:-2000}"
    mkdir -p "$WP_RULES"
    cat > "$WP_RULES/51-hifi-mic-priority.conf" <<EOF
monitor.alsa.rules = [
  {
    matches = [ { node.name = "~$pattern" } ]
    actions = {
      update-props = {
        priority.session = $prio
        priority.driver  = $prio
      }
    }
  }
]
EOF
    systemctl --user restart wireplumber 2>/dev/null
    echo "Mic preferred (regex): $pattern (priority $prio)"
}

cmd_mic_rules() {
    echo "Active mic rules:"
    for f in "$WP_RULES"/*.conf; do
        [ -f "$f" ] && grep -q "priority.session" "$f" 2>/dev/null && echo "  $(basename "$f")"
    done
}

cmd_mic_unprefer() {
    rm -f "$WP_RULES/51-hifi-mic-priority.conf" 2>/dev/null
    systemctl --user restart wireplumber 2>/dev/null
    echo "Mic preference removed"
}

# ── Combined Sink ─────────────────────────────────────────────────────────
cmd_combine() {
    local name="$1"; shift
    mkdir -p "$(dirname "$PW_FILTER")"
    local matches=""
    for sink in "$@"; do
        matches+="                        { node.name = \"$sink\" }
"
    done
    cat > "$(dirname "$PW_FILTER")/51-combine-$name.conf" <<EOF
context.modules = [
  {   name = libpipewire-module-combine-stream
      args = {
          combine.mode = sink
          node.name    = "combined_$name"
          node.description = "$name"
          combine.props = { audio.position = [ FL FR ] }
          stream.props = {}
          stream.rules = [
              {
                  matches = [
$matches
                  ]
                  actions = { create-stream = {} }
              }
          ]
      }
  }
]
EOF
    systemctl --user restart pipewire wireplumber 2>/dev/null
    echo "Combined sink: $name (from: $*)"
}

cmd_combine_remove() {
    rm -f "$(dirname "$PW_FILTER")/51-combine-$1.conf" 2>/dev/null
    systemctl --user restart pipewire wireplumber 2>/dev/null
    echo "Removed combined sink: $1"
}

# ── EasyEffects ───────────────────────────────────────────────────────────
cmd_ee_list() {
    local dir="${XDG_CONFIG_HOME:-$HOME/.config}/easyeffects/input"
    echo "EasyEffects input presets:"
    [ -d "$dir" ] && for f in "$dir"/*.json; do
        [ -f "$f" ] && echo "  $(basename "$f" .json)"
    done || echo "  (none)"
    dir="${XDG_CONFIG_HOME:-$HOME/.config}/easyeffects/output"
    echo "EasyEffects output presets:"
    [ -d "$dir" ] && for f in "$dir"/*.json; do
        [ -f "$f" ] && echo "  $(basename "$f" .json)"
    done || echo "  (none)"
}

cmd_ee_load() { easyeffects --load-preset "$1" 2>/dev/null && echo "Loaded: $1"; }
cmd_ee_start() { systemctl --user start easyeffects 2>/dev/null && echo "EasyEffects started"; }
cmd_ee_stop() { systemctl --user stop easyeffects 2>/dev/null && echo "EasyEffects stopped"; }

# ── Auto ──────────────────────────────────────────────────────────────────
cmd_auto() {
    echo "=== HiFi Suite Auto-Setup ==="
    echo ""

    # Detect headset
    local status=$(send "status" 2>/dev/null)
    if [[ "$status" == *device=* ]]; then
        echo "Headset: $(echo "$status" | sed 's/.*device=\([^ ]*\).*/\1/')"
    else
        echo "No headset detected. Connect and retry."
        return 1
    fi

    # Auto-enable NC (creates virtual mic with noise cancellation)
    echo ""
    echo "--- Noise Cancellation ---"
    cmd_enable nc 2>/dev/null

    # Check surround
    echo ""
    echo "--- Surround Sound ---"
    if command -v virtual-surround-manager &>/dev/null; then
        echo "virtual-surround-manager: installed"
        echo "  Run 'hifi-suite enable surround' to launch GUI"
    elif flatpak list --app 2>/dev/null | grep -qi virtual_surround_manager; then
        echo "virtual-surround-manager: installed (Flatpak)"
        echo "  Run 'hifi-suite enable surround' to launch GUI"
    else
        echo "virtual-surround-manager: not installed"
        echo "  Install: yay -S virtual-surround-manager"
    fi

    # Start daemon
    echo ""
    echo "--- Daemon ---"
    cmd_daemon start 2>/dev/null

    echo ""
    echo "=== Done ==="
    echo ""
    echo "What was set up:"
    echo "  - Virtual mic 'Noise Cancelling Mic' → select as input in your app"
    echo "  - Daemon running → volume sync active"
    echo ""
    echo "Next steps:"
    echo "  - For surround: hifi-suite enable surround"
    echo "  - For EQ: hifi-suite enable eq"
    echo "  - For all effects: hifi-suite effects"
}

# ── Daemon ────────────────────────────────────────────────────────────────
cmd_daemon() {
    case "${1:-start}" in
        start)
            systemctl --user start hifi-daemon 2>/dev/null \
                || nohup python3 "$(dirname "$0")/hifi-daemon.py" &>/dev/null &
            echo "Daemon started" ;;
        stop)
            systemctl --user stop hifi-daemon 2>/dev/null \
                || pkill -f hifi-daemon.py 2>/dev/null
            echo "Daemon stopped" ;;
        restart)
            systemctl --user restart hifi-daemon 2>/dev/null \
                || { cmd_daemon stop; cmd_daemon start; } ;;
        status)
            systemctl --user status hifi-daemon 2>/dev/null \
                || pgrep -f hifi-daemon.py >/dev/null && echo "Running" || echo "Stopped" ;;
    esac
}

# ── Main ──────────────────────────────────────────────────────────────────
[ $# -eq 0 ] && { usage; exit 0; }

case "$1" in
    vol|volume)     shift; cmd_vol "$@" ;;
    status)         send "status" ;;
    devices)        cmd_devices ;;
    default)        cmd_default ;;
    enable)         shift; cmd_enable "$1" ;;
    disable)        shift; cmd_disable "$1" ;;
    effects)        cmd_effects ;;
    mic-prefer)     shift; cmd_mic_prefer "$@" ;;
    mic-prefer-regex) shift; cmd_mic_prefer_regex "$@" ;;
    mic-rules)      cmd_mic_rules ;;
    mic-unprefer)   cmd_mic_unprefer ;;
    combine)        shift; cmd_combine "$@" ;;
    combine-remove) shift; cmd_combine_remove "$@" ;;
    ee-list)        cmd_ee_list ;;
    ee-load)        shift; cmd_ee_load "$@" ;;
    ee-start)       cmd_ee_start ;;
    ee-stop)        cmd_ee_stop ;;
    auto)           cmd_auto ;;
    daemon)         shift; cmd_daemon "$@" ;;
    help|-h|--help) usage ;;
    *) echo "Unknown: $1" >&2; usage; exit 1 ;;
esac
