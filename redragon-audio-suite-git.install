# Post-installation script for Redragon Audio Suite

post_install() {
    echo ""
    echo "=========================================="
    echo "  Redragon Audio Suite Installed! 🎧"
    echo "=========================================="
    echo ""
    echo "📌 Next steps:"
    echo ""
    echo "  1️⃣ Enable the control daemon service:"
    echo "     systemctl --user enable --now redragon-control-daemon.service"
    echo ""
    echo "  2️⃣ Run the setup wizard to configure virtual surround:"
    echo "     sudo redragon-audio-setup"
    echo ""
    echo "  3️⃣ Install virtual-surround-manager (recommended):"
    echo "     yay -S virtual-surround-manager"
    echo ""
    echo "  4️⃣ Set 'Virtual Surround Sink' as default in pavucontrol (if using manual config)"
    echo ""
    echo "📖 For more details, see:"
    echo "     /usr/share/doc/redragon-audio-suite/QUICKSTART.md"
    echo ""
    echo "🔗 Useful resources:"
    echo "     virtual-surround-manager: https://github.com/Berny23/virtual-surround-manager"
    echo "     AutoEq (for EQ): https://autoeq.app"
    echo ""
    echo "=========================================="
    echo ""
}

post_upgrade() {
    echo ""
    echo "=========================================="
    echo "  Redragon Audio Suite Updated! 🔄"
    echo "=========================================="
    echo ""
    echo "If you encounter any issues, rerun the setup wizard:"
    echo "  sudo redragon-audio-setup"
    echo ""
}

pre_remove() {
    echo ""
    echo "=========================================="
    echo "  Removing Redragon Audio Suite"
    echo "=========================================="
    echo ""
    echo "Stopping services..."
    systemctl --user stop redragon-control-daemon.service 2>/dev/null || true
    systemctl --user stop filter-chain.service 2>/dev/null || true
    echo "✅ Services stopped"
    echo ""
}

post_remove() {
    echo ""
    echo "=========================================="
    echo "  Redragon Audio Suite Removed"
    echo "=========================================="
    echo ""
    echo "If you want to completely remove all configuration files:"
    echo "  rm -rf /etc/pipewire/filter-chain.conf.d/"
    echo "  rm -rf /etc/pipewire/pipewire.conf.d/"
    echo ""
    echo "To also remove user data:"
    echo "  rm -rf ~/.local/share/redragon-hs-companion/"
    echo "  rm -rf ~/.config/redragon-audio-suite/"
    echo ""
}
